{
  "name": "server",
  "private": true,
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch --env-file .env src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "db:generate": "node --env-file=.env ../node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env ../node_modules/drizzle-kit/bin.cjs migrate",
    "db:migrate:test": "node --env-file=.env.test ../node_modules/drizzle-kit/bin.cjs migrate",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "eslint .",
    "test": "node --env-file=.env.test ../node_modules/vitest/vitest.mjs run",
    "test:watch": "node --env-file=.env.test ../node_modules/vitest/vitest.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@runeboard/schemas": "*",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "postgres": "^3.4.8",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "drizzle-kit": "^0.31.10",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.2",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.17.0",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
